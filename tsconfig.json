{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@env/*": ["./src/environments/*"],
      "@spartan-ng/helm/button": ["./src/app/ui/button/src/index.ts"],
      "@spartan-ng/helm/utils": ["./src/app/ui/utils/src/index.ts"],
      "@spartan-ng/helm/card": ["./src/app/ui/card/src/index.ts"],
      "@spartan-ng/helm/icon": ["./src/app/ui/icon/src/index.ts"],
      "@spartan-ng/helm/tabs": ["./src/app/ui/tabs/src/index.ts"],
      "@spartan-ng/helm/field": ["./src/app/ui/field/src/index.ts"],
      "@spartan-ng/helm/label": ["./src/app/ui/label/src/index.ts"],
      "@spartan-ng/helm/separator": ["./src/app/ui/separator/src/index.ts"],
      "@spartan-ng/helm/input": ["./src/app/ui/input/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./src/app/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/breadcrumb": ["./src/app/ui/breadcrumb/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["./src/app/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/alert-dialog": ["./src/app/ui/alert-dialog/src/index.ts"],
      "@spartan-ng/helm/dialog": ["./src/app/ui/dialog/src/index.ts"],
      "@spartan-ng/helm/table": ["./src/app/ui/table/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
